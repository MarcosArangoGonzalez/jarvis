#!/bin/bash

# 1. Ignorar el propio script de hook y archivos de configuración conocidos
# 2. Buscar patrones que parezcan claves reales (no solo el nombre de la variable)
# 3. Permitir el uso de placeholders tipo ${VAR} o os.getenv("VAR")

# Regex mejorada: busca el prefijo seguido de caracteres típicos de una clave, 
# evitando placeholders comunes de shell o python.
PATTERNS="(sk-[A-Za-z0-9_-]{20,}|ghp_[A-Za-z0-9_]{20,}|xox[baprs]-[A-Za-z0-9-]{20,})"

# Archivos en el área de stage (excluyendo el propio hook)
FILES=$(git diff --cached --name-only | grep -v ".githooks/pre-commit")

if [ -z "$FILES" ]; then exit 0; fi

FORBIDDEN_FOUND=$(git diff --cached -- $FILES | grep -E "$PATTERNS" | grep -vE "(\$\{|=.*getenv|DEFAULT_PIPER)")

if [ ! -z "$FORBIDDEN_FOUND" ]; then
    echo "❌ Jarvis Kernel: Posible secreto REAL detectado en los cambios."
    echo "$FORBIDDEN_FOUND"
    echo "Commit bloqueado por seguridad. Revisa las claves antes de continuar."
    exit 1
fi
